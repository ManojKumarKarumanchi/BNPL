# GrabCredit BNPL - Environment Variables
# Copy this file to .env and fill in your actual values
#
# IMPORTANT:
# - Backend variables go in backend/.env
# - Frontend variables go in frontend/.env
# - This file serves as a reference for all required variables

# ==============================================================================
# BACKEND ENVIRONMENT VARIABLES (backend/.env)
# ==============================================================================

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# Path to SQLite database (generated by synthetic-data-gen)
# Relative path from backend/ directory
DATABASE_PATH=./synthetic-data-gen/output/grabon_bnpl.db

# -----------------------------------------------------------------------------
# Azure OpenAI Configuration (for AI-generated credit narratives)
# -----------------------------------------------------------------------------
# Get these credentials from Azure Portal > Azure OpenAI Service
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com
AZURE_OPENAI_KEY=your-api-key-here
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-5.1
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AI_PROVIDER=azure
# Optional: Set to "false" to disable Azure OpenAI and use fallback narratives
AZURE_OPENAI_ENABLED=true

# -----------------------------------------------------------------------------
# MCP Server Configuration
# -----------------------------------------------------------------------------
# MCP server listens on this host and port
MCP_SERVER_HOST=localhost
MCP_SERVER_PORT=8001

# -----------------------------------------------------------------------------
# FastAPI Server Configuration
# -----------------------------------------------------------------------------
# Backend REST API server settings
# API_HOST=localhost
# API_PORT=8000
ENVIRONMENT=development

# CORS allowed origins (comma-separated for multiple origins)
# Add your frontend URL here
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# -----------------------------------------------------------------------------
# PayU LazyPay Integration (Optional - Sandbox)
# -----------------------------------------------------------------------------
# PayU sandbox credentials (for EMI disbursal integration)
# Leave empty to use local EMI calculation as fallback
PAYU_MERCHANT_KEY=your-payu-merchant-key
PAYU_MERCHANT_SALT=your-payu-merchant-salt
PAYU_BASE_URL=https://sandboxsecure.payu.in

# -----------------------------------------------------------------------------
# Redis Configuration (Optional - for caching & rate limiting)
# -----------------------------------------------------------------------------
# Redis is optional - system works without it
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0

# Cache TTL in seconds (default: 1 hour)
# CACHE_TTL=3600

# -----------------------------------------------------------------------------
# Rate Limiting Configuration
# -----------------------------------------------------------------------------
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=500

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=./logs/backend.log

# ==============================================================================
# FRONTEND ENVIRONMENT VARIABLES (frontend/.env)
# ==============================================================================

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
# Backend API base URL (must match backend API_HOST and API_PORT)
VITE_API_BASE_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Feature Flags (Optional)
# -----------------------------------------------------------------------------
# Enable/disable real-time API mode by default
# VITE_DEFAULT_API_MODE=false

# Show/hide persona switcher panel
# VITE_SHOW_PERSONA_SWITCHER=true

# Enable debug mode (shows API request/response logs in console)
# VITE_DEBUG_MODE=false
