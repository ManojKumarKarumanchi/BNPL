# GrabOn BNPL - Environment Variables Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# FastAPI Server Configuration
# =============================================================================

# Application Settings
APP_NAME=GrabOn BNPL API
APP_VERSION=1.0.0
DEBUG=true

# Server Settings
HOST=0.0.0.0
PORT=8000

# CORS Origins (comma-separated list)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001,http://localhost:5173

# =============================================================================
# MCP Server Configuration
# =============================================================================

# MCP Server URL for FastAPI to connect to
MCP_SERVER_URL=http://localhost:8001

# MCP Server Settings
MCP_SERVER_NAME=grabon-bnpl-mcp
MCP_SERVER_VERSION=1.0.0
MCP_SERVER_PORT=8001

# =============================================================================
# Database Configuration
# =============================================================================

# Path to SQLite database (relative or absolute)
# Default: backend/synthetic-data-gen/output/grabon_bnpl.db
# DATABASE_PATH=path/to/your/database.db

# =============================================================================
# JWT Authentication
# =============================================================================

# IMPORTANT: Change this secret key in production!
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# =============================================================================
# Rate Limiting
# =============================================================================

RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=500

# =============================================================================
# PayU LazyPay Integration (Optional)
# =============================================================================

# Set to "true" to enable PayU API integration
# Default: false (uses local EMI calculation)
PAYU_ENABLED=false

# PayU Sandbox URL
PAYU_SANDBOX_URL=https://test.payu.in

# PayU Credentials (get from https://dashboard.payu.in/merchant-onboarding)
# These are example values - replace with your actual test credentials
PAYU_MERCHANT_KEY=gtKFFx
PAYU_MERCHANT_SALT=4R38IvwiV57FwVpsgOvTXBdLE4tHUXFW
PAYU_MODE=sandbox

# API Base URL (for PayU callbacks)
API_BASE_URL=http://localhost:8000

# =============================================================================
# AI Provider Configuration
# =============================================================================

# AI Provider: "claude" or "azure"
AI_PROVIDER=claude

# Claude API (Anthropic)
# Get your API key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-5

# Azure OpenAI (Alternative to Claude)
# AZURE_AI_PROJECT_ENDPOINT=https://your-endpoint.openai.azure.com/
# AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-4
# AZURE_API_KEY=your_azure_api_key_here
# AZURE_API_VERSION=2025-04-01-preview

# =============================================================================
# Logging Configuration
# =============================================================================

# Log Level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log File Path (relative or absolute)
LOG_FILE=logs/mcp-server.log

# =============================================================================
# Redis Configuration (Optional - Currently Commented Out)
# =============================================================================

# REDIS_URL=redis://localhost:6379
# CACHE_TTL=3600

# =============================================================================
# Notes
# =============================================================================
#
# 1. **Security**: Never commit the .env file to git. It's already in .gitignore.
#
# 2. **Production Deployment**:
#    - Change JWT_SECRET_KEY to a strong random value
#    - Set DEBUG=false
#    - Update CORS_ORIGINS to your production frontend URL
#    - Set up proper ANTHROPIC_API_KEY
#
# 3. **PayU Integration**:
#    - Set PAYU_ENABLED=true only after getting valid sandbox credentials
#    - Test with PayU test cards before going to production
#
# 4. **Database Path**:
#    - Default uses synthetic data from: backend/synthetic-data-gen/output/grabon_bnpl.db
#    - For production, point to your production database
#
# 5. **MCP Server**:
#    - Ensure MCP_SERVER_URL matches where your MCP server is running
#    - Default: http://localhost:8001
#
