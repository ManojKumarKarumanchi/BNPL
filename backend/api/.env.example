# GrabOn BNPL API Configuration

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=True

# CORS - Frontend URLs
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# MCP Server
MCP_SERVER_URL=http://localhost:8001

# PayU LazyPay Integration
# Get sandbox credentials from: https://docs.payu.in/docs/getting-started
PAYU_MERCHANT_KEY=gtKFFx  # Sandbox test key (replace with your key)
PAYU_MERCHANT_SALT=4R38IvwiV57FwVpsgOvTXBdLE4tHUXFW  # Sandbox salt (replace with your salt)
PAYU_SANDBOX_URL=https://sandbox.payu.in
PAYU_MODE=sandbox  # "sandbox" or "production"
PAYU_ENABLED=true  # Set to "false" to use local EMI calculation

# API Base URL (for PayU callbacks)
